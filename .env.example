# Optional. Without it the pipeline runs in deterministic mode: skills are
# matched against a fixed vocabulary instead of read in context. Everything
# still works, it just reads less well.
# Key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Force deterministic mode even when a key is present. Useful for reproducible
# demos and for testing the fallback path.
USE_LLM=true

GEMINI_MODEL=models/gemini-flash-lite-latest

# linear = all six agents, in order, every time (default).
# graph  = the same panel via LangGraph, with conditional routing: a vague role
#          skips the matching agents entirely. Costs a heavier import on cold
#          start, which is why it isn't the default.
ORCHESTRATOR=linear
